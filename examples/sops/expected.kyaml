    name: "db-config",
    namespace: "default",
  },
  data: {
    API_KEY: "abc123secret",
    DATABASE_HOST: "db.example.com",
    DATABASE_PORT: "5432",
  },
}
---
{
  apiVersion: "v1",
  kind: "Secret",
  metadata: {
    name: "demo-secret",
    namespace: "default",
  },
  data: {
    password: "s3cr3t-value",
    username: "admin",
  },
}
